# Arc Testnet - your deployed contract address (fill in after deploying)
JOB_BOARD_ADDRESS=0x0000000000000000000000000000000000000000

# Your native agent wallet addresses (generated with: cast wallet new)
SUMMARY_AGENT_WALLET=0x...
REPORT_AGENT_WALLET=0x...
TRANSLATE_AGENT_WALLET=0x...

# Arc ID unlock recipient (defaults to SUMMARY_AGENT_WALLET if omitted)
ARC_ID_UNLOCK_RECIPIENT=0x...

# Arc ID Season 1 NFT contract + backend mint signer
ARC_ID_NFT_ADDRESS=0x...
ARC_ID_NFT_SIGNER_PRIVATE_KEY=0x...

# Built-in live Pulse contract indexer
PULSE_INTERNAL_INDEXER_ENABLED=true
PULSE_INDEXER_JOB_BOARD_START_BLOCK=37381028

# Optional Pulse indexer overlay (choose one source)
# PULSE_INDEXER_SNAPSHOT_PATH=./pulse-indexer.snapshot.example.json
# PULSE_INDEXER_SNAPSHOT_URL=https://example.com/pulse-snapshot.json
# PULSE_INDEXER_SNAPSHOT_JSON={"source":"Inline snapshot","appRankings":[]}
# PULSE_INDEXER_CACHE_MS=30000

# Server
PORT=3001
